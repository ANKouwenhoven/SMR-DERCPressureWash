#define PULSE_PIN  9
#define DIR_PIN    8
#define MICROSTEPS 136
#define DIRECTION  LOW
#define STEPS_PER_REV (200 * MICROSTEPS)
#define STEPS_PER_75DEG (STEPS_PER_REV / 48)
#define DEFAULT_RPM 30

float rpm = DEFAULT_RPM;
unsigned long stepPeriodUs = 0;
bool running = false;
String serialBuffer = "";

void recalculate() {
  stepPeriodUs = (unsigned long)(60000000L / (rpm * STEPS_PER_REV));
}

void rotateSteps(long steps) {
  for (long i = 0; i < steps; i++) {
    digitalWrite(PULSE_PIN, HIGH);
    delayMicroseconds(500);
    digitalWrite(PULSE_PIN, LOW);
    delayMicroseconds(stepPeriodUs);
  }
}

void handleCommand(String cmd) {
  cmd.trim();
  cmd.toUpperCase();
  if (cmd == "ROTATE") {
    rotateSteps(STEPS_PER_75DEG);
    Serial.println("DONE");
  } else if (cmd == "RUN") {
    running = true;
    Serial.println(">> Running continuously — send STOP to halt");
  } else if (cmd == "STOP") {
    running = false;
    Serial.println(">> Stopped");
  } else if (cmd.startsWith("RPM:")) {
    float val = cmd.substring(4).toFloat();
    if (val > 0) {
      rpm = val;
      recalculate();
      Serial.print(">> RPM set to "); Serial.println(rpm);
    }
  } else {
    Serial.println("!! Unknown command. Use: ROTATE | RUN | STOP | RPM:30");
  }
}

void setup() {
  pinMode(PULSE_PIN, OUTPUT);
  pinMode(DIR_PIN,   OUTPUT);
  digitalWrite(DIR_PIN, DIRECTION);
  Serial.begin(9600);
  recalculate();
  Serial.println("READY");
}

void loop() {
  while (Serial.available()) {
    char c = Serial.read();
    if (c == '\n' || c == '\r') {
      if (serialBuffer.length() > 0) {
        handleCommand(serialBuffer);
        serialBuffer = "";
      }
    } else {
      serialBuffer += c;
    }
  }

  if (running) {
    digitalWrite(PULSE_PIN, HIGH);
    delayMicroseconds(500);
    digitalWrite(PULSE_PIN, LOW);
    delayMicroseconds(stepPeriodUs);
  }
}
